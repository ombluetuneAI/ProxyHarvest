# Cache
.cache/

# Local config override (user-specific settings, not tracked in git)
config/settings.local.yaml

# Output - intermediate/temporary files
# (Final output files like nodes_*.yaml, nodes_*.txt are tracked in git)
output/meta*.json
output/out*.json
output/pingonly*.json
output/singbox_*.json
output/speedtest_singbox.json
output/speedtest_input*
output/speedtest_clean.json
output/speedtest_config*
output/speedtest_small*
output/test*
output/v2rayfree_raw.txt
output/tmp/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg

# Tools binaries — excluded from git, use scripts/setup.ps1 to install
tools/subconverter/
tools/singtools/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Subconverter runtime files
tools/subconverter/*/cache/
tools/subconverter/*/pref.toml

# Temp
*.tmp
*.bak

